# Model provider: fake, openai, or ollama.
# fake runs out-of-the-box; switch to openai for real agent behavior.
MODEL_PROVIDER=fake
MODEL_NAME=fake-document-reviewer
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Search provider: mock by default; replace behind SearchProvider in real projects.
SEARCH_PROVIDER=mock

# Persistence and storage.
DATABASE_URL=sqlite:///./deep_agents_demo.db
STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=.local_storage

# API metadata.
APP_NAME=Deep Agents FastAPI Sample
DEBUG=false
